# =============================================================================
# Cosmos Fraud Detection – Docker Compose Default Environment Variables
#
# Copy this file to .env.local and override values for your machine.
# Never commit secrets to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_VERSION=latest
SPRING_PROFILES_ACTIVE=docker

# JVM memory settings for application containers
APP_JAVA_OPTS=-XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0

# JWT issuer URI (replace with your real identity provider in staging/prod)
JWT_ISSUER_URI=https://auth.example.com/realms/cosmos

# ---------------------------------------------------------------------------
# Kafka (KRaft)
# ---------------------------------------------------------------------------
KAFKA_VERSION=8.1.2

# Must be a valid 22-character base64url string.
# Generate a new one with: docker run --rm confluentinc/cp-kafka:8.1.2 kafka-storage random-uuid
KAFKA_KRAFT_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

KAFKA_NUM_PARTITIONS=6

# Broker JVM heap size
KAFKA_HEAP_OPTS=-Xmx512m -Xms256m

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_VERSION=7-alpine

# Per-node max memory (6 nodes × this value = total cluster memory usage)
REDIS_MAX_MEMORY=256mb

# ---------------------------------------------------------------------------
# ScyllaDB
# ---------------------------------------------------------------------------
SCYLLA_VERSION=6.0

# ---------------------------------------------------------------------------
# ClickHouse
# ---------------------------------------------------------------------------
CLICKHOUSE_VERSION=24.3
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=fraud_analytics

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
JAEGER_VERSION=1.54
JAEGER_MAX_TRACES=10000

PROMETHEUS_VERSION=v2.50.1
PROMETHEUS_RETENTION=7d

GRAFANA_VERSION=10.3.3
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
