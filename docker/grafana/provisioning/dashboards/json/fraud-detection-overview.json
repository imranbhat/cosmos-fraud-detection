      "id": 11,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "title": "Response Latency p99 by Service",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=~\".*service|gateway\"}[1m])) by (le, job))", "legendFormat": "{{job}} p99", "refId": "A" },
        { "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=~\".*service|gateway\"}[1m])) by (le, job))", "legendFormat": "{{job}} p50", "refId": "B" }
      ]
    },
