{
  "name": "@cosmos/fraud-sdk-react-native",
  "version": "1.0.0",
  "description": "Cosmos Fraud Detection React Native SDK for mobile device fingerprinting and behavioral signals",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src"
  ],
  "scripts": {
    "test": "jest",
    "lint": "eslint src/"
  },
  "keywords": [
    "fraud-detection",
    "fingerprinting",
    "behavioral-analytics",
    "cosmos",
    "react-native"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.71.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^12.4.0",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.3.0",
    "@types/react-native": "^0.73.0",
    "jest": "^29.7.0",
    "react-test-renderer": "^18.2.0",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.test.tsx"
    ],
    "moduleNameMapper": {
      "^react-native$": "<rootDir>/__mocks__/react-native.ts"
    },
    "globals": {
      "ts-jest": {
        "tsconfig": {
          "target": "ES2020",
          "lib": ["ES2020"],
          "jsx": "react-jsx",
          "esModuleInterop": true,
          "strict": true
        }
      }
    }
  }
}
